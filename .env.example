# IMPORTANT: localhost does not work from a real phone.
# Use your machine LAN IP, Expo tunnel, or a reachable backend URL.
# Example LAN: http://192.168.1.50:3000
EXPO_PUBLIC_API_BASE_URL=http://YOUR_BACKEND_HOST:3000

EXPO_PUBLIC_API_TIMEOUT_SALES=10000
EXPO_PUBLIC_API_TIMEOUT_REPORTS=30000
EXPO_PUBLIC_LOG_LEVEL=debug
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_SESSION_IDLE_TIMEOUT_MS=900000
EXPO_PUBLIC_AUTO_LOCK_ENABLED=true
