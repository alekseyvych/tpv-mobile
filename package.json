{
  "name": "tpv-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "mobile:phone": "powershell -ExecutionPolicy Bypass -File scripts/mobile-start-android.ps1 -AvdName tpv_phone",
    "mobile:tablet": "powershell -ExecutionPolicy Bypass -File scripts/mobile-start-android.ps1 -AvdName tpv_tablet",
    "mobile:phone:reset": "powershell -ExecutionPolicy Bypass -File scripts/mobile-start-android.ps1 -AvdName tpv_phone -WipeData",
    "mobile:tablet:reset": "powershell -ExecutionPolicy Bypass -File scripts/mobile-start-android.ps1 -AvdName tpv_tablet -WipeData",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "check:design-drift": "powershell -ExecutionPolicy Bypass -File scripts/check-design-drift.ps1",
    "e2e:maestro:first-init": "maestro test e2e/maestro/first-init.yaml",
    "e2e:maestro:card-payment": "maestro test e2e/maestro/card-payment.yaml",
    "e2e:maestro:kitchen": "maestro test e2e/maestro/kitchen-status.yaml",
    "e2e:maestro:all": "maestro test e2e/maestro",
    "doctor": "npx expo-doctor",
    "e2e:build": "detox build-framework-cache && detox build-app --configuration ios.sim.debug",
    "e2e:build-release": "detox build-app --configuration ios.sim.release",
    "e2e:test": "detox test e2e --configuration ios.sim.debug --cleanup --record-logs all --record-logs all",
    "e2e:test:auth": "detox test e2e/auth.e2e.ts --configuration ios.sim.debug --cleanup",
    "e2e:test:dining": "detox test e2e/diningFloor.e2e.ts --configuration ios.sim.debug --cleanup",
    "e2e:test:kitchen": "detox test e2e/kitchen.e2e.ts --configuration ios.sim.debug --cleanup",
    "e2e:test:checkout": "detox test e2e/checkout.e2e.ts --configuration ios.sim.debug --cleanup",
    "e2e:test:token-refresh": "detox test e2e/tokenRefresh.e2e.ts --configuration ios.sim.debug --cleanup",
    "e2e:test:errors": "detox test e2e/errorScenarios.e2e.ts --configuration ios.sim.debug --cleanup"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.14.14",
    "@shopify/react-native-skia": "2.2.12",
    "axios": "^1.16.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-font": "~14.0.11",
    "expo-localization": "~17.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.1.0",
    "react": "19.1.0",
    "react-i18next": "^17.0.7",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.32.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^54.0.10",
    "detox": "^20.50.4",
    "detox-cli": "^20.50.4",
    "detox-server": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "http-proxy-agent": "^7.0.2",
    "@tootallnate/once": "^3.0.1"
  },
  "private": true
}
